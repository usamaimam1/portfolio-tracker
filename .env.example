# Supabase (client — safe to expose anon key)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: override sync endpoint (default /api/sync-indexes on Netlify)
# VITE_SYNC_URL=/api/sync-indexes

# Netlify Functions only (never expose in client — no VITE_ prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=random-secret-for-scheduled-jobs

# Optional — email delivery disabled in app; leave unset
# RESEND_API_KEY=re_xxx
# REPORT_EMAIL_FROM=PSX Portfolio <reports@yourdomain.com>
